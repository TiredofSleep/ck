# ================================================================
#  CK .gitignore -- Keep the repo clean
# ================================================================

# ── Secrets ──
.api_key
.env
.env.*

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── Compiled binaries (rebuild from source) ──
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.dat
*.bin

# ── CK runtime state (generated as CK runs) ──
ck_development.json
ck_dictionary_learned.json
concept_mass.json
gpu_tl.json
truth_lattice.json
ck_tl.bin
ck_daemon_log.jsonl
btq_results.json
ck_pos_cache.json

# ── Logs (generated at runtime) ──
*.log
api_log.txt
bible_reading_log.txt
nt_reading_log.txt
gcc_err.txt

# ── CK persistence (grows at runtime) ──
lattice_chain/

# ── Clay results (reproducible via CLI) ──
results/

# ── Vivado / FPGA build artifacts ──
*.jou
*.backup.jou
.Xil/
vivado*.backup.*
dfx_runtime.txt

# ── ELF binaries (rebuild from source) ──
*.elf

# ── Temp training scripts (not part of core) ──
ck_train_loop*.py


# ── Thesis output (generated at runtime) ──
thesis_*.md

# ── OS junk ──
.DS_Store
Thumbs.db
desktop.ini
nul

# ── IDE / tool state ──
.vscode/
.idea/
*.swp
*.swo
*~
.claude/

# ── Generated dictionary files (rebuild via build_dictionary.py) ──
targets/website/ck_dictionary.json
targets/website/ck_dict_tier2.json
targets/website/ck_dict.js
targets/website/ck_dict_tier1.js

# ── Archive (old Gen9 files) ──
archive/
