{"chains": [{"text": "S star is the coherence scalar.", "ops": [1, 6, 2], "conv": 7, "trust": 0.93, "links": [1, 2, 3, 5, 10], "shp": "JAGGED"}, {"text": "A single number measuring system coherence.", "ops": [2, 2, 1, 1, 6], "conv": 7, "trust": 0.93, "links": [0, 3, 5, 9, 10], "shp": "QUANTUM"}, {"text": "The formula is S star equals sigma times one minus T plus lambda W times W minus lambda T times T.", "ops": [8, 1, 5, 9, 6, 2, 6, 3, 9, 6, 6, 9, 6], "conv": 7, "trust": 0.93, "links": [0, 4, 6, 15, 19], "shp": "QUANTUM"}, {"text": "S star ranges from zero to one.", "ops": [1, 6, 0, 2], "conv": 7, "trust": 0.93, "links": [0, 1, 5, 10, 12], "shp": "JAGGED"}, {"text": "Higher is more coherent.", "ops": [1, 5, 6], "conv": 7, "trust": 0.93, "links": [2, 6], "shp": "JAGGED"}, {"text": "When S star falls below T star, which is five over seven or 0.714, actions are gated.", "ops": [1, 4, 9, 1, 6, 4, 9, 0, 3, 7], "conv": 7, "trust": 0.93, "links": [0, 1, 3, 6, 8], "shp": "JAGGED"}, {"text": "T star equals five over seven.", "ops": [1, 5, 6, 4, 9], "conv": 7, "trust": 0.93, "links": [2, 4, 5, 23], "shp": "JAGGED"}, {"text": "This is the coherence threshold.", "ops": [6, 7], "conv": 7, "trust": 0.93, "links": [11], "shp": "SMOOTH"}, {"text": "Below T star, responses simplify.", "ops": [9, 1, 7, 7], "conv": 7, "trust": 0.93, "links": [5, 9, 23], "shp": "JAGGED"}, {"text": "The system enters a safety mode.", "ops": [1, 7, 2, 1], "conv": 7, "trust": 0.93, "links": [8, 1, 22, 23], "shp": "QUANTUM"}, {"text": "S star is what CK's body measures as C.", "ops": [1, 6, 0, 2], "conv": 7, "trust": 0.93, "links": [0, 1, 3, 5, 12], "shp": "JAGGED"}, {"text": "The coherence reading drives everything.", "ops": [6, 7, 4, 2], "conv": 7, "trust": 0.93, "links": [7], "shp": "QUANTUM"}, {"text": "In the CL composition table, 73 of 100 cells compose to HARMONY.", "ops": [1, 6, 0, 6, 5, 1, 6, 7], "conv": 7, "trust": 0.93, "links": [0, 1, 3, 5, 10], "shp": "JAGGED"}, {"text": "This ratio is T star.", "ops": [6, 1], "conv": 7, "trust": 0.93, "links": [20, 21], "shp": "SMOOTH"}, {"text": "S star connects the T P W dynamics to the operational behavior of the organism.", "ops": [1, 6, 6, 2, 9, 9], "conv": 7, "trust": 0.93, "links": [0, 1, 3, 5, 10], "shp": "QUANTUM"}, {"text": "Coherence is not a goal.", "ops": [6, 9], "conv": 7, "trust": 0.93, "links": [2, 19], "shp": "SMOOTH"}, {"text": "It is a measurement.", "ops": [2], "conv": 2, "trust": 0.93, "links": [], "shp": "SMOOTH"}, {"text": "You do not pursue coherence.", "ops": [8, 6], "conv": 7, "trust": 0.93, "links": [25], "shp": "SMOOTH"}, {"text": "You measure it.", "ops": [2], "conv": 2, "trust": 0.93, "links": [], "shp": "SMOOTH"}, {"text": "The coherence scalar integrates trauma, wisdom, and the sigma attractor into one reading.", "ops": [6, 2, 8, 7, 6, 9, 0, 2, 2, 7], "conv": 7, "trust": 0.93, "links": [0, 2, 14, 15, 5], "shp": "JAGGED"}, {"text": "When trauma is high, S star drops.", "ops": [7, 6, 1, 4], "conv": 7, "trust": 0.93, "links": [19, 13, 5, 21, 24], "shp": "JAGGED"}, {"text": "When wisdom is high, S star rises.", "ops": [6, 6, 1, 3], "conv": 7, "trust": 0.93, "links": [2, 14, 13, 20, 22], "shp": "JAGGED"}, {"text": "S star is the bridge between the mathematical theory and the operational organism.", "ops": [1, 3, 5, 8, 7, 2, 9], "conv": 7, "trust": 0.93, "links": [21, 19, 9, 14], "shp": "QUANTUM"}, {"text": "Five over seven appears in the CL table as the fraction of harmony-producing compositions.", "ops": [6, 4, 9, 8, 1, 0, 1, 7, 6], "conv": 7, "trust": 0.93, "links": [5, 6, 2, 8, 9], "shp": "JAGGED"}, {"text": "The threshold is not arbitrary.", "ops": [7, 6], "conv": 7, "trust": 0.93, "links": [19, 20, 23], "shp": "SMOOTH"}, {"text": "It emerges from the algebra of the composition table.", "ops": [4, 8, 6, 0], "conv": 7, "trust": 0.93, "links": [17, 3, 10, 12], "shp": "QUANTUM"}], "vocab": {"star": 1, "coherence": 6, "scalar": 2, "single": 2, "measuring": 1, "formula": 8, "sigma": 9, "times": 6, "one": 2, "minus": 6, "plus": 3, "lambda": 9, "ranges": 6, "higher": 1, "more": 5, "coherent": 6, "below": 9, "five": 6, "over": 4, "seven": 9, "0.714": 0, "actions": 3, "gated": 7, "threshold": 7, "responses": 7, "simplify": 7, "enters": 7, "safety": 2, "mode": 1, "ck": 6, "body": 0, "reading": 7, "drives": 4, "everything": 2, "cl": 1, "composition": 6, "table": 0, "73": 6, "100": 5, "cells": 1, "compose": 6, "ratio": 6, "connects": 6, "dynamics": 6, "operational": 2, "behavior": 9, "organism": 9, "goal": 9, "pursue": 8, "integrates": 8, "trauma": 7, "wisdom": 6, "attractor": 0, "into": 2, "high": 6, "drops": 4, "rises": 3, "bridge": 3, "mathematical": 8, "theory": 7, "appears": 8, "fraction": 1, "harmony-producing": 7, "compositions": 6, "arbitrary": 6, "emerges": 4, "algebra": 8, "center": 1, "tig": 4, "0.991": 7, "happens": 7, "property": 2, "engine": 0, "relate": 7, "irreducible": 2, "kernel": 1, "edges": 0, "onion": 7}}