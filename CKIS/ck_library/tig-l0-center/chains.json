{"chains": [{"text": "The center of TIG is the Zero-Dynamics Manifold where trauma equals zero and processing equals zero.", "ops": [1, 4, 9, 2, 7, 5, 0, 2, 5, 0], "conv": 7, "trust": 0.95, "links": [1, 4, 7, 9, 10], "shp": "QUANTUM"}, {"text": "On the zero-dynamics manifold, wisdom W is free to take any value between zero and one.", "ops": [9, 2, 6, 1, 1, 8, 1, 5, 0, 2], "conv": 7, "trust": 0.95, "links": [0, 2, 8, 9, 13], "shp": "QUANTUM"}, {"text": "The center is a one-dimensional line in three-dimensional state space.", "ops": [1, 8, 4, 7, 1, 3], "conv": 7, "trust": 0.95, "links": [1, 12, 15, 17, 22], "shp": "QUANTUM"}, {"text": "All trauma has been processed at the center.", "ops": [3, 7, 2, 1], "conv": 7, "trust": 0.95, "links": [15], "shp": "QUANTUM"}, {"text": "No active processing remains.", "ops": [6, 2, 7], "conv": 7, "trust": 0.95, "links": [0, 10, 12, 19, 21], "shp": "ROLLING"}, {"text": "Only wisdom persists.", "ops": [0, 6, 7], "conv": 7, "trust": 0.95, "links": [6, 8], "shp": "SMOOTH"}, {"text": "Your position on the zero-dynamics line is determined entirely by accumulated wisdom.", "ops": [5, 9, 4, 4, 6, 0, 6], "conv": 7, "trust": 0.95, "links": [5, 7, 19], "shp": "JAGGED"}, {"text": "The center is not a point but a line.", "ops": [1, 4, 4], "conv": 7, "trust": 0.95, "links": [0, 6, 20], "shp": "JAGGED"}, {"text": "The dimension of freedom is wisdom itself.", "ops": [6, 1, 6, 7], "conv": 7, "trust": 0.95, "links": [1, 5], "shp": "JAGGED"}, {"text": "At the center, T equals zero, P equals zero, and W lives on the interval from zero to one.", "ops": [1, 5, 0, 5, 0, 7, 9, 0, 2], "conv": 7, "trust": 0.95, "links": [1, 0, 17, 19], "shp": "JAGGED"}, {"text": "The manifold is analytically derived.", "ops": [2, 7, 4], "conv": 7, "trust": 0.95, "links": [0, 4, 12], "shp": "ROLLING"}, {"text": "It is not a numerical approximation.", "ops": [2, 9], "conv": 9, "trust": 0.95, "links": [], "shp": "QUANTUM"}, {"text": "Every trajectory in TIG state space eventually converges toward this line.", "ops": [2, 7, 4, 1, 3, 2, 7, 7, 4], "conv": 7, "trust": 0.95, "links": [0, 4, 10, 2, 13], "shp": "JAGGED"}, {"text": "The center is what remains after all processing is complete.", "ops": [1, 7, 0, 3, 2, 6], "conv": 7, "trust": 0.95, "links": [12, 1, 19, 22], "shp": "JAGGED"}, {"text": "It is the residue of experience.", "ops": [7, 3], "conv": 7, "trust": 0.95, "links": [], "shp": "SMOOTH"}, {"text": "To reach the center, all trauma must be processed.", "ops": [7, 1, 3, 7, 7, 2], "conv": 7, "trust": 0.95, "links": [2, 12, 3, 17, 22], "shp": "JAGGED"}, {"text": "There are no shortcuts.", "ops": [0], "conv": 0, "trust": 0.95, "links": [], "shp": "SMOOTH"}, {"text": "The zero-dynamics manifold is the attractor of the entire T P W system.", "ops": [9, 2, 0, 7, 1], "conv": 7, "trust": 0.95, "links": [0, 1, 9, 2, 15], "shp": "QUANTUM"}, {"text": "Coherence is maximal at the center.", "ops": [6, 5, 1], "conv": 7, "trust": 0.95, "links": [], "shp": "ROLLING"}, {"text": "S star equals sigma times one minus zero equals sigma.", "ops": [1, 5, 9, 6, 2, 6, 0, 5, 9], "conv": 7, "trust": 0.95, "links": [1, 9, 6, 4, 13], "shp": "JAGGED"}, {"text": "The center is not emptiness.", "ops": [1, 4], "conv": 7, "trust": 0.95, "links": [0, 7], "shp": "JAGGED"}, {"text": "It is fully processed experience crystallized as wisdom.", "ops": [6, 2, 3, 6, 6], "conv": 7, "trust": 0.95, "links": [4, 19], "shp": "ROLLING"}, {"text": "Below the center is reality itself, which no formal system can access or describe completely.", "ops": [9, 1, 7, 7, 1, 1, 6, 6], "conv": 7, "trust": 0.95, "links": [13, 12, 15, 2, 17], "shp": "JAGGED"}], "vocab": {"center": 1, "tig": 4, "zero-dynamics": 9, "manifold": 2, "trauma": 7, "processing": 2, "wisdom": 6, "free": 1, "take": 1, "any": 8, "value": 1, "one": 2, "one-dimensional": 8, "line": 4, "three-dimensional": 7, "state": 1, "space": 3, "all": 3, "processed": 2, "active": 6, "remains": 7, "only": 0, "persists": 7, "position": 5, "determined": 4, "entirely": 6, "accumulated": 0, "point": 4, "dimension": 6, "freedom": 1, "itself": 7, "lives": 7, "interval": 9, "analytically": 7, "derived": 4, "numerical": 2, "approximation": 9, "every": 2, "trajectory": 7, "eventually": 2, "toward": 7, "after": 0, "complete": 6, "residue": 7, "experience": 3, "reach": 7, "must": 7, "shortcuts": 0, "attractor": 0, "entire": 7, "coherence": 6, "maximal": 5, "star": 1, "sigma": 9, "times": 6, "minus": 6, "emptiness": 4, "fully": 6, "crystallized": 6, "below": 9, "reality": 7, "formal": 1, "access": 6, "0.991": 7, "happens": 7, "high": 6, "safety": 2, "property": 2, "body": 0, "engine": 0, "relate": 7, "irreducible": 2, "kernel": 1, "edges": 0, "onion": 7}}