{"chains": [{"text": "Three coupled differential equations govern experience becoming wisdom.", "ops": [7, 6, 1, 5, 7, 3, 9, 6], "conv": 7, "trust": 0.9, "links": [13, 16, 17, 25, 28], "shp": "QUANTUM"}, {"text": "dT/dt equals negative alpha times P times T.", "ops": [9, 5, 9, 8, 6, 6], "conv": 7, "trust": 0.9, "links": [3, 12, 14, 17, 20], "shp": "ROLLING"}, {"text": "Processing reduces trauma over time.", "ops": [2, 7, 7, 4, 1], "conv": 7, "trust": 0.9, "links": [4, 6, 9, 13, 14], "shp": "ROLLING"}, {"text": "dP/dt equals beta times T minus gamma times P.", "ops": [5, 5, 9, 1, 6, 5, 1], "conv": 7, "trust": 0.9, "links": [1, 12, 26, 32], "shp": "JAGGED"}, {"text": "Trauma calls for processing.", "ops": [7, 7, 2], "conv": 7, "trust": 0.9, "links": [2, 7, 9, 10, 12], "shp": "SMOOTH"}, {"text": "Processing decays naturally.", "ops": [2, 4, 8], "conv": 8, "trust": 0.9, "links": [15, 18, 19], "shp": "QUANTUM"}, {"text": "dW/dt equals delta times P times one minus W.", "ops": [2, 5, 4, 1, 1, 2, 6], "conv": 7, "trust": 0.9, "links": [2, 20, 26, 30, 32], "shp": "QUANTUM"}, {"text": "Processing builds wisdom, bounded at one.", "ops": [2, 3, 6, 7, 2], "conv": 7, "trust": 0.9, "links": [4, 10, 12, 18, 24], "shp": "ROLLING"}, {"text": "Processing is the engine.", "ops": [2, 0], "conv": 0, "trust": 0.9, "links": [], "shp": "ROLLING"}, {"text": "Without processing, trauma remains.", "ops": [6, 2, 7, 7], "conv": 7, "trust": 0.9, "links": [2, 4, 13, 14, 23], "shp": "ROLLING"}, {"text": "Without trauma, processing has no fuel.", "ops": [6, 7, 2, 8], "conv": 7, "trust": 0.9, "links": [7, 4, 12, 24, 25], "shp": "ROLLING"}, {"text": "Wisdom is the integral of processing.", "ops": [6, 4, 2], "conv": 7, "trust": 0.9, "links": [14, 16, 18], "shp": "QUANTUM"}, {"text": "It accumulates but never exceeds one.", "ops": [5, 9, 7, 2], "conv": 7, "trust": 0.9, "links": [1, 3, 4, 7, 10], "shp": "SMOOTH"}, {"text": "The coupling creates a natural sequence: trauma triggers processing which builds wisdom.", "ops": [6, 3, 9, 9, 7, 7, 2, 3, 6], "conv": 7, "trust": 0.9, "links": [0, 12, 2, 4, 9], "shp": "QUANTUM"}, {"text": "Alpha controls how fast processing resolves trauma.", "ops": [8, 6, 4, 2, 7, 7], "conv": 7, "trust": 0.9, "links": [1, 11, 2, 9, 4], "shp": "QUANTUM"}, {"text": "Higher alpha means faster healing.", "ops": [1, 8, 4, 8], "conv": 7, "trust": 0.9, "links": [5], "shp": "QUANTUM"}, {"text": "Beta controls how strongly trauma activates processing.", "ops": [9, 6, 1, 7, 4, 2], "conv": 7, "trust": 0.9, "links": [0, 2, 11, 14, 18], "shp": "QUANTUM"}, {"text": "Higher beta means more responsive.", "ops": [1, 9, 5, 7], "conv": 7, "trust": 0.9, "links": [1, 0, 25, 29, 30], "shp": "JAGGED"}, {"text": "Gamma controls how fast processing decays without trauma.", "ops": [5, 6, 4, 2, 4, 6, 7], "conv": 7, "trust": 0.9, "links": [11, 14, 16, 5, 7], "shp": "QUANTUM"}, {"text": "It prevents infinite rumination.", "ops": [2, 4, 4], "conv": 7, "trust": 0.9, "links": [5, 18, 21], "shp": "QUANTUM"}, {"text": "Delta controls how efficiently processing converts to wisdom.", "ops": [4, 6, 0, 2, 6, 6], "conv": 7, "trust": 0.9, "links": [18, 6, 1, 26], "shp": "JAGGED"}, {"text": "Higher delta means faster learning.", "ops": [1, 4, 4, 3], "conv": 7, "trust": 0.9, "links": [19, 27], "shp": "JAGGED"}, {"text": "The system is dissipative.", "ops": [1, 0], "conv": 0, "trust": 0.9, "links": [], "shp": "SMOOTH"}, {"text": "Energy flows from trauma through processing into wisdom.", "ops": [0, 8, 7, 7, 2, 2, 6], "conv": 7, "trust": 0.9, "links": [2, 4, 9, 13, 14], "shp": "ROLLING"}, {"text": "Trauma that is not processed does not heal.", "ops": [7, 2, 0], "conv": 7, "trust": 0.9, "links": [4, 7, 10, 12, 13], "shp": "SMOOTH"}, {"text": "The equation requires active P to reduce T.", "ops": [5, 7, 6, 7], "conv": 7, "trust": 0.9, "links": [0, 17, 7, 10, 18], "shp": "SMOOTH"}, {"text": "The one minus W term in wisdom growth creates a saturation effect.", "ops": [2, 6, 5, 6, 3, 3, 8, 1], "conv": 7, "trust": 0.9, "links": [6, 20, 23, 3, 18], "shp": "ROLLING"}, {"text": "Learning slows as mastery approaches.", "ops": [3, 4, 3, 2], "conv": 7, "trust": 0.9, "links": [21], "shp": "ROLLING"}, {"text": "These equations describe the same process whether applied to a person, an organism, or a culture.", "ops": [5, 2, 2, 7, 5, 7, 9, 2], "conv": 7, "trust": 0.9, "links": [23, 2, 9, 14, 0], "shp": "QUANTUM"}, {"text": "The T P W system is domain-invariant.", "ops": [1, 9], "conv": 7, "trust": 0.9, "links": [17], "shp": "JAGGED"}, {"text": "It works the same in psychology, biology, and information theory.", "ops": [2, 5, 7, 0, 7], "conv": 7, "trust": 0.9, "links": [6, 0, 17, 25, 28], "shp": "JAGGED"}, {"text": "Recovery from trauma is exponential at first, then slows.", "ops": [7, 7, 3, 2, 4], "conv": 7, "trust": 0.9, "links": [2, 4, 9, 13, 14], "shp": "QUANTUM"}, {"text": "This matches clinical observation.", "ops": [1, 1, 6], "conv": 7, "trust": 0.9, "links": [6, 3], "shp": "JAGGED"}, {"text": "Multiple trauma events compound.", "ops": [6, 7, 2, 6], "conv": 7, "trust": 0.9, "links": [7, 10, 18, 25, 4], "shp": "ROLLING"}, {"text": "Each adds to T, requiring proportionally more processing.", "ops": [1, 2, 7, 2, 5, 2], "conv": 7, "trust": 0.9, "links": [6, 2, 9, 14, 28], "shp": "QUANTUM"}], "vocab": {"three": 7, "coupled": 6, "differential": 1, "equations": 5, "govern": 7, "experience": 3, "becoming": 9, "wisdom": 6, "dt/dt": 9, "negative": 9, "alpha": 8, "times": 6, "processing": 2, "reduces": 7, "trauma": 7, "over": 4, "time": 1, "dp/dt": 5, "beta": 9, "minus": 6, "gamma": 5, "calls": 7, "naturally": 8, "dw/dt": 2, "delta": 4, "one": 2, "bounded": 7, "engine": 0, "without": 6, "remains": 7, "fuel": 8, "integral": 4, "accumulates": 5, "never": 9, "exceeds": 7, "coupling": 6, "natural": 9, "sequence": 9, "triggers": 7, "controls": 6, "fast": 4, "higher": 1, "faster": 4, "healing": 8, "strongly": 1, "activates": 4, "more": 5, "responsive": 7, "prevents": 2, "in