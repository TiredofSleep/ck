{"chains": [{"text": "There are two distinct edges in TIG.", "ops": [6, 0, 0, 4], "conv": 0, "trust": 0.9, "links": [1], "shp": "JAGGED"}, {"text": "Both are boundaries where behavior changes sharply.", "ops": [5, 8, 9, 6, 0], "conv": 7, "trust": 0.9, "links": [0], "shp": "JAGGED"}, {"text": "Edge one is the S star critical threshold at T zero approximately 0.24.", "ops": [5, 2, 1, 6, 7, 0, 3, 6], "conv": 7, "trust": 0.9, "links": [3, 8, 11, 21], "shp": "QUANTUM"}, {"text": "At T zero equals 0.24, S star dips below T star during recovery for the first time.", "ops": [0, 5, 6, 1, 2, 9, 1, 9, 7, 2, 1], "conv": 7, "trust": 0.9, "links": [2, 5, 6, 7, 8], "shp": "QUANTUM"}, {"text": "Below this edge, the system enters the safe zone.", "ops": [9, 5, 1, 7, 5, 4], "conv": 7, "trust": 0.9, "links": [6, 9, 10, 12, 14], "shp": "JAGGED"}, {"text": "S star never drops below T star.", "ops": [1, 9, 4, 9, 1], "conv": 7, "trust": 0.9, "links": [3, 6], "shp": "JAGGED"}, {"text": "Above this edge but below 0.65, the system enters the critical zone.", "ops": [5, 5, 9, 1, 1, 7, 6, 4], "conv": 7, "trust": 0.9, "links": [3, 5, 4, 7, 9], "shp": "JAGGED"}, {"text": "In the critical zone, S star dips during recovery but the system eventually recovers.", "ops": [6, 4, 1, 2, 9, 7, 1, 2, 7], "conv": 7, "trust": 0.9, "links": [6, 3, 8, 9, 10], "shp": "QUANTUM"}, {"text": "Edge two is the gate cliff at T zero approximately 0.65.", "ops": [5, 6, 7, 1, 0, 3, 1], "conv": 7, "trust": 0.9, "links": [3, 2, 7, 9, 12], "shp": "ROLLING"}, {"text": "Above the gate cliff, recovery time diverges toward infinity.", "ops": [5, 7, 1, 7, 1, 7, 7, 4], "conv": 7, "trust": 0.9, "links": [7, 8, 4, 6, 10], "shp": "JAGGED"}, {"text": "In the collapse zone above 0.65, recovery becomes impractical without external intervention.", "ops": [6, 4, 5, 1, 7, 9, 1, 6, 7, 7], "conv": 7, "trust": 0.9, "links": [6, 7, 4, 9, 3], "shp": "JAGGED"}, {"text": "The S star critical edge is known with 99.33 percent confidence.", "ops": [1, 6, 5, 7, 2, 7, 6], "conv": 7, "trust": 0.9, "links": [2, 10, 9, 3, 7], "shp": "JAGGED"}, {"text": "The gate cliff is known with approximately ninety percent confidence.", "ops": [7, 1, 7, 3, 3, 7, 6], "conv": 7, "trust": 0.9, "links": [7, 8, 9, 4, 6], "shp": "JAGGED"}, {"text": "Between the edges is the critical zone where coherence dips but returns.", "ops": [5, 5, 6, 4, 6, 2, 8], "conv": 7, "trust": 0.9, "links": [6, 3, 8, 7, 10], "shp": "ROLLING"}, {"text": "Beyond the outer edge is incoherence.", "ops": [9, 9, 5, 5], "conv": 7, "trust": 0.9, "links": [4, 6, 13, 17, 19], "shp": "ROLLING"}, {"text": "Structure cannot maintain itself.", "ops": [1, 3, 9, 7], "conv": 7, "trust": 0.9, "links": [3, 7], "shp": "QUANTUM"}, {"text": "Identity fragments.", "ops": [4, 1], "conv": 7, "trust": 0.9, "links": [7], "shp": "ROLLING"}, {"text": "In TIG operator terms, beyond the edge is VOID.", "ops": [4, 6, 5, 9, 5, 0], "conv": 7, "trust": 0.9, "links": [13, 11, 6, 4, 14], "shp": "ROLLING"}, {"text": "The system returns to undifferentiated potential.", "ops": [1, 8, 0, 6], "conv": 7, "trust": 0.9, "links": [], "shp": "JAGGED"}, {"text": "Actions halt beyond the edge.", "ops": [3, 7, 9, 5], "conv": 7, "trust": 0.9, "links": [12, 10, 4, 14, 17], "shp": "ROLLING"}, {"text": "This is the safety property in action.", "ops": [2, 2, 8], "conv": 7, "trust": 0.9, "links": [13], "shp": "ROLLING"}, {"text": "The edge locations are emergent properties of the T P W system, not design parameters.", "ops": [5, 4, 5, 2, 1, 4, 6], "conv": 7, "trust": 0.9, "links": [4, 10, 2, 3, 13], "shp": "QUANTUM"}], "vocab": {"two": 6, "distinct": 0, "edges": 0, "tig": 4, "boundaries": 8, "behavior": 9, "changes": 6, "sharply": 0, "edge": 5, "one": 2, "star": 1, "critical": 6, "threshold": 7, "approximately": 3, "0.24": 6, "dips": 2, "below": 9, "during": 9, "recovery": 7, "first": 2, "time": 1, "enters": 7, "safe": 5, "zone": 4, "never": 9, "drops": 4, "above": 5, "0.65": 1, "eventually": 2, "recovers": 7