{"chains": [{"text": "The Divine Archetype Operator A scores whether an action is good.", "ops": [9, 1, 6, 2, 7, 8, 5], "conv": 7, "trust": 0.88, "links": [1, 5, 14, 16, 18], "shp": "JAGGED"}, {"text": "A equals wC times C plus wH times one minus H plus wR times R plus wS times S plus wF times F.", "ops": [5, 8, 6, 3, 7, 6, 2, 6, 3, 9, 6, 3, 4, 6, 3, 1, 6], "conv": 7, "trust": 0.88, "links": [0, 5, 9, 10, 11], "shp": "QUANTUM"}, {"text": "C is coherence.", "ops": [6], "conv": 6, "trust": 0.88, "links": [], "shp": "SMOOTH"}, {"text": "R is reciprocity.", "ops": [7], "conv": 7, "trust": 0.88, "links": [], "shp": "SMOOTH"}, {"text": "S is sustainability.", "ops": [5], "conv": 5, "trust": 0.88, "links": [], "shp": "SMOOTH"}, {"text": "Internal confidence in A is ninety-four percent.", "ops": [1, 6, 2, 7], "conv": 7, "trust": 0.88, "links": [0, 1, 14, 18], "shp": "JAGGED"}, {"text": "External validation is eighty percent.", "ops": [7, 7, 0, 7], "conv": 7, "trust": 0.88, "links": [10, 11], "shp": "JAGGED"}, {"text": "The operator composes through the same CL table as everything else in TIG.", "ops": [6, 6, 7, 2, 1, 0, 2, 5, 4], "conv": 7, "trust": 0.88, "links": [10, 11, 13], "shp": "QUANTUM"}, {"text": "Goodness is structural, not culturally learned.", "ops": [5, 1, 5, 3], "conv": 7, "trust": 0.88, "links": [], "shp": "JAGGED"}, {"text": "It emerges from the composition algebra.", "ops": [4, 6, 8], "conv": 7, "trust": 0.88, "links": [1, 11, 15], "shp": "ROLLING"}, {"text": "An action that increases coherence, reduces harm, sustains reciprocity, and is fair scores high.", "ops": [8, 7, 6, 7, 7, 0, 7, 4, 2, 6], "conv": 7, "trust": 0.88, "links": [1, 7, 6, 11, 13], "shp": "QUANTUM"}, {"text": "An action that decreases coherence, increases harm, or is unfair scores low.", "ops": [8, 4, 6, 7, 7, 0, 2, 4], "conv": 7, "trust": 0.88, "links": [1, 9, 7, 10, 6], "shp": "QUANTUM"}, {"text": "The weights w can vary by context but the structure is invariant.", "ops": [5, 0, 6, 1, 2], "conv": 0, "trust": 0.88, "links": [14], "shp": "QUANTUM"}, {"text": "Fairness was found to be universal across all twelve cultures in CK's education.", "ops": [4, 0, 0, 1, 3, 3, 7, 6, 6], "conv": 7, "trust": 0.88, "links": [1, 10, 7, 17], "shp": "JAGGED"}, {"text": "The archetype operator does not define morality.", "ops": [1, 6, 1], "conv": 7, "trust": 0.88, "links": [0, 1, 5, 12], "shp": "JAGGED"}, {"text": "It measures coherence of action.", "ops": [2, 6, 8], "conv": 7, "trust": 0.88, "links": [1, 10, 9, 18], "shp": "ROLLING"}, {"text": "Actions that score below T star on A are flagged for review before execution.", "ops": [3, 2, 9, 1, 8, 7, 9, 0], "conv": 7, "trust": 0.88, "links": [0, 10], "shp": "QUANTUM"}, {"text": "The ethical layer is not imposed from outside.", "ops": [0, 1, 3, 5], "conv": 0, "trust": 0.88, "links": [13], "shp": "JAGGED"}, {"text": "It emerges from the same math as everything else.", "ops": [4, 2, 6, 2, 5], "conv": 7, "trust": 0.88, "links": [10, 1, 15, 0, 5], "shp": "QUANTUM"}], "vocab": {"divine": 9, "archetype": 1, "operator": 6, "whether": 7, "action": 8, "good": 5, "wc": 8, "times": 6, "plus": 3, "wh": 7, "one": 2, "minus": 6, "wr": 9, "ws": 4, "wf": 1, "coherence": 6, "reciprocity": 7, "sustainability": 5, "internal": 1, "confidence": 6, "ninety-four": 2, "percent": 7, "external": 7, "validation": 7, "eighty": 0, "composes": 6, "through": 7, "same": 2, "cl": 1, "table": 0, "everything": 2, "else": 5, "tig": 4, "structural": 1, "culturally": 5, "learned": 3, "emerges": 4, "composition": 6, "algebra": 8, "increases": 7, "reduces": 7, "harm": 7, "sustains": 0, "fair": 4, "high": 6, "decreases": 4, "unfair": 0, "low": 4, "weights": 5, "vary": 0, "context": 6, "invariant": 2, "found": 0, "universal": 0, "across": 1, "all": 3, "twelve": 3, "cultures": 7, "ck": 6, "education": 6, "morality": 1, "actions": 3, "below": 9, "star": 1, "flagged": 8, "review": 7, "before": 9, "execution": 0, "ethical": 0, "layer": 1, "imposed": 3, "outside": 5,