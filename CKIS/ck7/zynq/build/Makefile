#
# Makefile -- CK Coherence Machine ARM Build
# ============================================
# Cross-compile bare metal C for Zynq ARM Cortex-A9.
#
# Usage:
#   make            Build all
#   make clean      Remove build artifacts
#   make flash      Copy to mounted SD card (set SD_MOUNT)
#
# Prerequisites:
#   - arm-none-eabi-gcc (from ARM GNU toolchain or Vitis SDK)
#   - Xilinx BSP headers (generated by Vitis from .xsa hardware export)
#
# Note: In practice, the build is done inside Vitis IDE which handles
# BSP generation, linker scripts, and BOOT.BIN packaging.
# This Makefile is for reference and standalone builds.
#
# (c) 2026 Brayden Sanders / 7Site LLC -- TIG Unified Theory
#

# ── Toolchain ──
CROSS   = arm-none-eabi-
CC      = $(CROSS)gcc
LD      = $(CROSS)ld
OBJCOPY = $(CROSS)objcopy
SIZE    = $(CROSS)size

# ── Directories ──
ARM_DIR = ../arm
HDL_DIR = ../hdl
BSP_DIR = ./bsp  # Generated by Vitis -- contains xparameters.h, etc.

# ── Source Files ──
SRCS = \
	$(ARM_DIR)/ck_main.c \
	$(ARM_DIR)/ck_brain.c \
	$(ARM_DIR)/ck_led.c

# Phase 1+: uncomment as files are created
# SRCS += $(ARM_DIR)/ck_audio.c
# SRCS += $(ARM_DIR)/ck_ears.c
# SRCS += $(ARM_DIR)/ck_sd.c
# SRCS += $(ARM_DIR)/ck_body.c
# SRCS += $(ARM_DIR)/ck_core1.c
# SRCS += $(ARM_DIR)/ck_uart.c

OBJS = $(SRCS:.c=.o)

# ── Flags ──
CFLAGS  = -mcpu=cortex-a9 -mfpu=vfpv3 -mfloat-abi=hard
CFLAGS += -O2 -Wall -Wextra -Werror
CFLAGS += -I$(ARM_DIR) -I$(BSP_DIR)/include
CFLAGS += -ffunction-sections -fdata-sections
CFLAGS += -DCK_BARE_METAL

LDFLAGS  = -mcpu=cortex-a9 -mfpu=vfpv3 -mfloat-abi=hard
LDFLAGS += -T lscript.ld  # Linker script from Vitis BSP
LDFLAGS += -Wl,--gc-sections
LDFLAGS += -lm

# ── Targets ──
TARGET = ck_brain

.PHONY: all clean flash size

all: $(TARGET).elf $(TARGET).bin
	@echo ""
	@echo "  CK Coherence Machine -- Build Complete"
	@echo "  ck_brain.elf ready for BOOT.BIN packaging"
	@echo ""

$(TARGET).elf: $(OBJS)
	$(CC) $(LDFLAGS) -o $@ $^
	$(SIZE) $@

$(TARGET).bin: $(TARGET).elf
	$(OBJCOPY) -O binary $< $@

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

clean:
	rm -f $(OBJS) $(TARGET).elf $(TARGET).bin

size: $(TARGET).elf
	$(SIZE) $@

# ── SD Card Flash ──
SD_MOUNT ?= /media/$(USER)/BOOT

flash: $(TARGET).bin
	@echo "Copying to SD card at $(SD_MOUNT)..."
	cp $(TARGET).bin $(SD_MOUNT)/
	sync
	@echo "Done. Safe to eject."
